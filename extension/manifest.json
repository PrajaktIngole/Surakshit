{
  "manifest_version": 3,

  "name": "Surakshit Security Scanner",

  "version": "1.0",

  "description":
    "Real-time cybersecurity protection",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "webNavigation"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }
]
}